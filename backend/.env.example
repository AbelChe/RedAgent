# Project Configuration
PROJECT_NAME="RedAgent"

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5438/pentest

# Celery Task Queue Configuration (uses Redis)
CELERY_BROKER_URL=redis://localhost:6389/0
CELERY_RESULT_BACKEND=redis://localhost:6389/1

# LLM Configuration
# Options: anthropic, openai, deepseek, qwen
LLM_PROVIDER=

# Model Name
# Common options: claude-3-5-sonnet-20240620, gpt-4o, deepseek-chat
LLM_MODEL=

# API Key (Generic field for all providers)
LLM_API_KEY=sk-xxxxxxxxxxxx

# Optional: Custom Base URL (e.g. for DeepSeek/Local vLLM)
# LLM_API_BASE=https://api.deepseek.com/v1

# Legacy Support (will fallback to this if LLM_API_KEY is not set)
ANTHROPIC_AUTH_TOKEN=

# MCP Security (Shared Secret)
# Used as fallback if per-workspace token is missing (Dev only)
MCP_TOKEN=dev-token-placeholder

# MCP Connectivity
# Address for MCP containers to reach the Backend API
# Defaults to ws://host.docker.internal:8000 for Mac/Dev
# For Production (K8s/Linux): Set to internal service URL (e.g. ws://backend:8000)
MCP_BACKEND_URL=ws://host.docker.internal:8000
