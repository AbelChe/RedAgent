    "@types/ws": "^8.18.1",
    "dockerode": "^4.0.9",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0",
    "puppeteer": "^24.34.0",
    "ts-node": "^10.9.2",
