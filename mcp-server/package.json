{
  "name": "redagent-mcp-server",
  "version": "1.0.0",
  "description": "RedAgent MCP Server - AI-powered penetration testing tool execution engine following Model Context Protocol (MCP) standard.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "start:http": "tsc && node dist/index.js --mode http",
    "start:stdio": "tsc && node dist/index.js --mode stdio",
    "start:ws": "tsc && node dist/index.js --mode ws",
    "dev": "ts-node src/index.ts",
    "dev:http": "ts-node src/index.ts --mode http",
    "dev:stdio": "ts-node src/index.ts --mode stdio",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
