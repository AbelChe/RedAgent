# ============================================================
# RedAgent MCP Server - 独立 MCP 模式配置
# 适用于: IDE 直连 (VS Code / Claude Code / Cursor / Trae)
# 启动: npm run dev:http  或  npm run dev:stdio
# ============================================================

# --- 认证 ---
# HTTP 模式下的 Bearer Token (不设则跳过认证)
MCP_TOKEN=redagent-mcp-secret

# --- 传输 ---
# HTTP 端口 (仅 --mode http 时生效)
MCP_HTTP_PORT=3003

# 不要设 MCP_HUB_URL — 设了会自动切换到 ws 模式连接 Backend Hub
# MCP_HUB_URL=

# --- 容器配置 ---
CONTAINERS_CONFIG_PATH=./containers.yaml

# Docker Volume 名称 (工具容器挂载的共享卷)
WORKSPACE_VOLUME_NAME=redagent-workspace

# --- Bee Security Scan Platform ---
# Bee API 地址 (不设则 bee_scan/bee_status/bee_result 工具不可用)
BEE_API_URL=
# Bee API 认证 Token (可选, 不设则不带认证)
BEE_API_TOKEN=
# Bee 任务队列名称 (Temporal Task Queue, 必须与 Worker 注册的队列匹配)
BEE_TASK_QUEUE=

# --- Bee UnitFilter 单位名称验证服务 ---
# UnitFilter API 地址 (不设则 bee_verify_unit 工具不可用)
UNITFILTER_API_URL=
# UnitFilter API 认证 Token (可选)
UNITFILTER_API_TOKEN=

# --- Bee ICP 备案查询服务 ---
# ICP API 地址 (不设则 bee_icp_query 工具不可用)
ICP_API_URL=
# ICP API 认证 Token (可选)
ICP_API_TOKEN=

# --- Bee 网络地址查询服务 ---
# Addr API 地址 (不设则 bee_addr_query 工具不可用)
ADDR_API_URL=
# Addr API 认证 Token
ADDR_API_TOKEN=
