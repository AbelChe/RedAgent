{
  "mcpServers": {
    "redagent-local": {
      "command": "npx",
      "args": [
        "ts-node",
        "./mcp-server/src/index.ts",
        "--mode", "stdio"
      ],
      "env": {
        "CONTAINERS_CONFIG_PATH": "./mcp-server/containers.yaml",
        "BEE_API_URL": "",
        "BEE_API_TOKEN": ""
      }
    },
    "redagent-http": {
      "url": "http://localhost:3001/mcp",
      "headers": {
        "Authorization": "Bearer your-mcp-token"
      }
    }
  }
}
